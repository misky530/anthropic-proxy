# ── 上游网关配置 ─────────────────────────────────────────
# 你的 OpenAI 兼容网关地址（不含结尾斜杠）
UPSTREAM_BASE_URL=https://api.deepseek.com

# 统一 API Key（留空则透传用户自己的 key）
# 如果你的平台用统一 key + 用户标识另外传，就填这里
UPSTREAM_API_KEY=

# ── 服务配置 ─────────────────────────────────────────────
PORT=3456
DEBUG=false

# ── 模型映射（可选覆盖，留空用默认值）────────────────────
# Claude Code 默认请求 claude-sonnet-4-5，映射到你平台的实际模型名
MODEL_CLAUDE_OPUS=claude-opus-4-5
MODEL_CLAUDE_SONNET=deepseek-chat
MODEL_CLAUDE_HAIKU=qwen3-coder-next

# 未匹配时的兜底模型
DEFAULT_MODEL=deepseek-chat
